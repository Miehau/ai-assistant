# Server
NODE_ENV=development
PORT=3001
HOST=localhost

# Database. Use postgres for production deployments.
# Examples:
#   sqlite   -> DATABASE_URL=./data/app.db
#   postgres -> DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_DIALECT=sqlite
DATABASE_URL=./data/app.db

# Working directory for file and shell tools (relative paths resolve from here)
# WORKING_DIR=/Users/you/projects/myapp

# Default model (provider:model format)
DEFAULT_MODEL=anthropic:claude-sonnet-4-20250514

# LLM Provider API Keys (optional - only configure providers you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenRouter
OPENROUTER_API_KEY=

# --- Security / hardening ---

# Required in production. Generate with: openssl rand -base64 32
# Used to encrypt API keys and MCP credentials at rest.
ENCRYPTION_KEY=

# Comma-separated CORS origin allowlist. Empty = open CORS without credentials
# (safe because bearer-token auth is the actual gate).
# Example for Tauri: ALLOWED_ORIGINS=tauri://localhost,http://localhost:1420
ALLOWED_ORIGINS=

# Trust X-Forwarded-For / X-Real-IP from your reverse proxy or platform.
# Leave false if the app is directly exposed.
TRUST_PROXY=false

# Disabled by default. Setting this to true exposes /bin/sh -c to agents - only
# enable on isolated/sandboxed deployments.
ENABLE_SHELL_TOOL=false

# Rate limits (per minute). Logged at warn level when exceeded.
RATE_LIMIT_AUTH_FAILURE_PER_MIN=120
RATE_LIMIT_API_PER_MIN=60
RATE_LIMIT_INFERENCE_PER_MIN=60
RATE_LIMIT_TELEGRAM_PER_MIN=600
RATE_LIMIT_HEALTH_PER_MIN=20
