{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read:*",
      "Edit:*",
      "Write:*",
      "MultiEdit:*",
      "NotebookEdit:*",
      "Glob:*",
      "Grep:*",
      "Agent:*",
      "Bash(bun install*)",
      "Bash(bun add*)",
      "Bash(bun run*)",
      "Bash(npx drizzle-kit*)",
      "Bash(npx tsx*)",
      "Bash(cd server*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(node *)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "mysql",
    "sequential-thinking",
    "playwright"
  ]
}
